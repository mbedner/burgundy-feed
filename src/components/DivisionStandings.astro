---
// ─── NFC East Division Standings ──────────────────────────────────────────────
interface StandingsEntry {
  name:       string;   // team display name
  abbr:       string;   // team abbreviation
  wins:       number;
  losses:     number;
  ties:       number;
  pct:        string;   // e.g. ".647"
  isCommanders: boolean;
}
interface Props { entries: StandingsEntry[]; }
const { entries } = Astro.props;
if (!entries.length) return;
---

<div class="standings">
  <p class="standings-title">NFC East</p>
  <table class="standings-table" cellspacing="0" cellpadding="0">
    <thead>
      <tr>
        <th class="col-team">Team</th>
        <th class="col-num">W</th>
        <th class="col-num">L</th>
        {entries.some(e => e.ties > 0) && <th class="col-num">T</th>}
        <th class="col-pct">PCT</th>
      </tr>
    </thead>
    <tbody>
      {entries.map(e => (
        <tr class={e.isCommanders ? 'row--us' : ''}>
          <td class="col-team">{e.abbr}</td>
          <td class="col-num">{e.wins}</td>
          <td class="col-num">{e.losses}</td>
          {entries.some(x => x.ties > 0) && <td class="col-num">{e.ties}</td>}
          <td class="col-pct">{e.pct}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .standings {
    font-size: 13px;
  }

  .standings-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-4);
    margin: 0 0 8px;
  }

  .standings-table {
    width: 100%;
    border-collapse: collapse;
  }

  .standings-table th {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-4);
    padding: 0 4px 5px;
    border-bottom: 1px solid var(--border);
    text-align: left;
  }

  .standings-table td {
    padding: 5px 4px;
    color: var(--text-2);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  .standings-table tr:last-child td { border-bottom: none; }

  .col-team { width: 100%; font-weight: 600; font-size: 12px; }
  .col-num  { text-align: center; min-width: 22px; }
  .col-pct  { text-align: right; color: var(--text-4); font-size: 11px; }

  /* Highlight the Commanders row */
  .row--us td { color: var(--text-1); }
  .row--us .col-team {
    color: #9b1535;
    font-weight: 700;
  }
</style>
