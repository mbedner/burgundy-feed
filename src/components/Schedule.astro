---
import type { UPCOMING_SCHEDULE, LAST_SEASON } from '../config/schedule';
interface Props {
  schedule:   typeof UPCOMING_SCHEDULE;
  lastSeason: typeof LAST_SEASON;
}
const { schedule, lastSeason } = Astro.props;

const now = new Date();
const upcoming = schedule
  .filter(g => g.opponent !== 'BYE' && new Date(g.date + 'T12:00:00') >= now)
  .slice(0, 7);
const nextGame = upcoming[0] ?? null;
const rest = upcoming.slice(1);

function fmt(d: string): string {
  return new Date(d + 'T12:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', weekday: 'short' });
}
function fmtShort(d: string): string {
  return new Date(d + 'T12:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<div class="module">
  <div class="module-hd">2026 Schedule</div>

  {nextGame ? (
    <div class="next-game">
      <div class="next-pill">NEXT GAME</div>
      <div class="next-opp">{nextGame.home ? 'vs' : '@'} <strong>{nextGame.opponent}</strong></div>
      <div class="next-info">
        <span>{fmt(nextGame.date)}</span>
        {nextGame.time && nextGame.time !== 'TBD' && <span>· {nextGame.time}</span>}
        {nextGame.tv && nextGame.tv !== 'TBD'  && <span class="next-tv">· {nextGame.tv}</span>}
      </div>
      <div class="next-venue">{nextGame.home ? 'Home — Northwest Stadium' : 'Away'}</div>
    </div>
  ) : (
    <p class="no-data">Schedule pending</p>
  )}

  {rest.length > 0 && (
    <div class="sched-list">
      {rest.map(g => (
        <div class="sched-row">
          <span class="sched-wk">{g.week}</span>
          <span class="sched-ha">{g.home === null ? '—' : g.home ? 'vs' : '@'}</span>
          <span class="sched-opp">{g.opponent}</span>
          <span class="sched-dt">{fmtShort(g.date)}</span>
        </div>
      ))}
    </div>
  )}

  <p class="sched-note">Dates estimated — official schedule releases ~May 2026</p>

  <!-- 2025 Season Results -->
  <div class="season-hd">
    <span class="season-yr">{lastSeason.year} Season</span>
    <span class="season-rec">{lastSeason.record}</span>
  </div>

  <div class="results-list">
    {lastSeason.games.map(g => (
      <div class={`result-row result-${g.result.toLowerCase()}`}>
        <span class="res-wk">{g.week}</span>
        <span class="res-ha">{g.home === null ? '' : g.home ? 'vs' : '@'}</span>
        <span class="res-opp">{g.opponent}</span>
        {g.result !== '—' ? (
          <span class="res-score">{g.ws}–{g.os}</span>
        ) : (
          <span class="res-score res-bye">BYE</span>
        )}
        <span class={`res-tag res-tag--${g.result.toLowerCase()}`}>{g.result}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .module-hd {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .next-game {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    padding: 10px 12px;
    margin-bottom: 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .next-pill {
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: var(--accent);
  }
  .next-opp {
    font-size: 16px;
    color: var(--text);
    font-weight: 400;
    line-height: 1.2;
  }
  .next-opp strong { font-weight: 800; }
  .next-info {
    font-size: 12px;
    color: var(--text-2);
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }
  .next-tv { font-weight: 700; color: var(--accent); }
  .next-venue { font-size: 11px; color: var(--text-3); }

  .sched-list { display: flex; flex-direction: column; }
  .sched-row {
    display: grid;
    grid-template-columns: 28px 24px 1fr auto;
    gap: 4px;
    align-items: center;
    padding: 6px 0;
    border-bottom: 1px solid var(--border);
    font-size: 12px;
  }
  .sched-wk   { font-size: 10px; font-weight: 700; color: var(--text-4); }
  .sched-ha   { color: var(--text-3); font-size: 11px; }
  .sched-opp  { color: var(--text); font-weight: 600; }
  .sched-dt   { color: var(--text-3); text-align: right; white-space: nowrap; }
  .sched-note {
    font-size: 10px;
    color: var(--text-4);
    font-style: italic;
    margin: 6px 0 14px;
  }

  /* ── 2025 Results ──────────────────────────────────────────────────────── */
  .season-hd {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 10px 0 6px;
    border-top: 1px solid var(--border);
    margin-top: 4px;
  }
  .season-yr {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .season-rec {
    font-size: 13px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .results-list { display: flex; flex-direction: column; }
  .result-row {
    display: grid;
    grid-template-columns: 28px 18px 1fr auto 20px;
    gap: 3px;
    align-items: center;
    padding: 5px 0;
    border-bottom: 1px solid var(--border);
    font-size: 11px;
  }
  .res-wk   { font-size: 10px; font-weight: 700; color: var(--text-4); }
  .res-ha   { color: var(--text-3); font-size: 10px; }
  .res-opp  { color: var(--text-2); font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .res-score { color: var(--text-3); text-align: right; white-space: nowrap; font-size: 11px; font-variant-numeric: tabular-nums; }
  .res-bye  { color: var(--text-4); font-style: italic; }

  .res-tag {
    font-size: 9px;
    font-weight: 800;
    text-align: center;
    border-radius: 2px;
    padding: 1px 3px;
    letter-spacing: 0.04em;
  }
  .res-tag--w { color: #22c55e; }
  .res-tag--l { color: var(--text-4); }
  .res-tag--— { color: var(--text-4); }

  .no-data { font-size: 12px; color: var(--text-3); }
</style>
