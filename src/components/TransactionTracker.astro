---
import type { Article } from '../lib/types';

interface Props {
  items:  Article[];
  label:  string;
}

const { items, label } = Astro.props;

function rel(iso: string): string {
  const m = Math.floor((Date.now() - new Date(iso).getTime()) / 60000);
  if (m < 60)  return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24)  return `${h}h ago`;
  return `${Math.floor(h / 24)}d ago`;
}

const PRIORITY: Record<string, number> = { signing: 0, trade: 1, release: 2 };

function txTag(tags: string[]): 'signing' | 'trade' | 'release' {
  const hit = ['signing', 'trade', 'release'].find(t => tags.includes(t));
  return (hit as 'signing' | 'trade' | 'release') ?? 'signing';
}

const BADGE: Record<string, string> = {
  signing: 'SIGNED',
  trade:   'TRADE',
  release: 'RELEASED',
};

// Only show articles from the last 7 days to avoid historical false-positives
const SEVEN_DAYS = 7 * 24 * 60 * 60 * 1000;
const fresh = items.filter(a => Date.now() - new Date(a.publishedAt).getTime() < SEVEN_DAYS);
---

{fresh.length > 0 && (
  <div class="module">
    <div class="tx-hd">
      <div class="tx-hd-left">
        <span class="tx-dot"></span>
        <span class="tx-title">Transactions</span>
      </div>
      <span class="tx-label">{label}</span>
    </div>

    <div class="tx-list">
      {fresh.map(item => {
        const tag = txTag(item.tags);
        return (
          <a href={item.sourceUrl} target="_blank" rel="noopener noreferrer" class="tx-row">
            <div class="tx-top">
              <span class={`tx-badge tx-badge--${tag}`}>{BADGE[tag]}</span>
              <span class="tx-time">{rel(item.publishedAt)}</span>
            </div>
            <span class="tx-hed">{item.displayHeadline}</span>
            <span class="tx-source">{item.sourceName}</span>
          </a>
        );
      })}
    </div>
  </div>
)}

<style>
  /* ── Header ── */
  .tx-hd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  .tx-hd-left {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .tx-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--live-dot);
    flex-shrink: 0;
    animation: tx-blink 2.5s ease-in-out infinite;
  }
  @keyframes tx-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.25; }
  }
  .tx-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .tx-label {
    font-size: 9px;
    font-weight: 500;
    color: var(--text-4);
    letter-spacing: 0.04em;
    font-style: italic;
  }

  /* ── List ── */
  .tx-list {
    display: flex;
    flex-direction: column;
  }
  .tx-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.12s;
  }
  .tx-row:last-child { border-bottom: none; }

  /* ── Badge row ── */
  .tx-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .tx-badge {
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 2px 6px;
    border-radius: 3px;
  }
  /* Signing — gold tint */
  .tx-badge--signing {
    background: var(--gold-bg);
    color: var(--gold);
  }
  /* Trade — burgundy tint */
  .tx-badge--trade {
    background: rgba(155, 21, 53, 0.15);
    color: var(--accent-alert);
  }
  /* Release — muted */
  .tx-badge--release {
    background: var(--surface-3);
    color: var(--text-3);
  }

  .tx-time {
    font-size: 10px;
    color: var(--text-4);
    white-space: nowrap;
    margin-left: auto;
  }

  /* ── Headline ── */
  .tx-hed {
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.12s;
  }
  .tx-row:hover .tx-hed { color: var(--accent); }

  /* ── Source ── */
  .tx-source {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-4);
  }
</style>
