---
import type { Article } from '../lib/types';

interface Props {
  items:  Article[];
  label:  string;
}

const { items, label } = Astro.props;

function rel(iso: string): string {
  const m = Math.floor((Date.now() - new Date(iso).getTime()) / 60000);
  if (m < 60)  return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24)  return `${h}h ago`;
  return `${Math.floor(h / 24)}d ago`;
}

// Pick the most transaction-relevant tag for the badge
const TRANSACTION_TAGS = ['signing', 'trade', 'release', 'suspension'] as const;
type TxTag = typeof TRANSACTION_TAGS[number];

function txTag(tags: string[]): TxTag {
  for (const t of TRANSACTION_TAGS) {
    if (tags.includes(t)) return t;
  }
  return 'signing';
}

const BADGE_LABEL: Record<TxTag, string> = {
  signing:    'SIGNED',
  trade:      'TRADE',
  release:    'RELEASED',
  suspension: 'SUSPENDED',
};
---

<section class="tx-tracker">
  <div class="tx-header">
    <span class="tx-dot"></span>
    <span class="tx-title">Transaction Wire</span>
    <span class="tx-label">{label}</span>
  </div>

  <div class="tx-list">
    {items.map(item => {
      const tag = txTag(item.tags);
      return (
        <a href={item.sourceUrl} target="_blank" rel="noopener noreferrer"
           class={`tx-row tx-row--${tag}`}>
          <span class={`tx-badge tx-badge--${tag}`}>{BADGE_LABEL[tag]}</span>
          <span class="tx-hed">{item.displayHeadline}</span>
          <span class="tx-meta">
            <span class="tx-source">{item.sourceName}</span>
            <span class="tx-dot-sep">·</span>
            <span class="tx-time">{rel(item.publishedAt)}</span>
          </span>
        </a>
      );
    })}
  </div>
</section>

<style>
  .tx-tracker {
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 20px;
    background: var(--surface-2);
  }

  /* ── Header ── */
  .tx-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    background: var(--surface-3);
    border-bottom: 1px solid var(--border);
  }
  .tx-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--live-dot);
    flex-shrink: 0;
    animation: tx-blink 2.5s ease-in-out infinite;
  }
  @keyframes tx-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.25; }
  }
  .tx-title {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .tx-label {
    font-size: 10px;
    font-weight: 500;
    color: var(--text-4);
    letter-spacing: 0.04em;
    margin-left: auto;
  }

  /* ── Rows ── */
  .tx-list {
    display: flex;
    flex-direction: column;
  }
  .tx-row {
    display: grid;
    grid-template-columns: 76px 1fr auto;
    align-items: center;
    gap: 10px;
    padding: 9px 14px;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.12s;
    min-width: 0;
  }
  .tx-row:last-child { border-bottom: none; }
  .tx-row:hover { background: var(--surface); }

  /* ── Badge ── */
  .tx-badge {
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 2px 6px;
    border-radius: 3px;
    text-align: center;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .tx-badge--signing    { background: #14532d; color: #4ade80; }
  .tx-badge--trade      { background: #1e3a5f; color: #60a5fa; }
  .tx-badge--release    { background: #3b1515; color: #f87171; }
  .tx-badge--suspension { background: #3b2500; color: #fb923c; }

  /* Light mode badge overrides */
  :root[data-theme="light"] .tx-badge--signing    { background: #dcfce7; color: #166534; }
  :root[data-theme="light"] .tx-badge--trade      { background: #dbeafe; color: #1d4ed8; }
  :root[data-theme="light"] .tx-badge--release    { background: #fee2e2; color: #991b1b; }
  :root[data-theme="light"] .tx-badge--suspension { background: #ffedd5; color: #9a3412; }

  /* ── Headline ── */
  .tx-hed {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.35;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    transition: color 0.12s;
  }
  .tx-row:hover .tx-hed { color: var(--accent); }

  /* ── Meta ── */
  .tx-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .tx-source {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-4);
  }
  .tx-dot-sep { display: none; }
  .tx-time {
    font-size: 10px;
    color: var(--text-4);
  }

  /* Wider screens: inline meta */
  @media (min-width: 560px) {
    .tx-meta {
      flex-direction: row;
      align-items: center;
      gap: 4px;
    }
    .tx-dot-sep { display: inline; color: var(--text-4); font-size: 10px; }
  }
</style>
