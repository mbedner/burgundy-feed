---
import TeamDates          from './TeamDates.astro';
import Schedule           from './Schedule.astro';
import TeamStats          from './TeamStats.astro';
import TransactionTracker from './TransactionTracker.astro';
import type { Article }   from '../lib/types';

interface Props {
  dates:        any;
  schedule:     any;
  lastSeason:   any;
  stats:        any;
  players:      any;
  txArticles?:  Article[];
  txLabel?:     string;
  showTx?:      boolean;
}

const { dates, schedule, lastSeason, stats, players,
        txArticles = [], txLabel = '', showTx = false } = Astro.props;
---

<div class="rail">
  {showTx && txArticles.length > 0 && (
    <div class="rail-section">
      <TransactionTracker items={txArticles} label={txLabel} />
    </div>
  )}
  <div class="rail-section">
    <Schedule schedule={schedule} lastSeason={lastSeason} />
  </div>
  <div class="rail-section">
    <TeamStats stats={stats} players={players} />
  </div>
  <div class="rail-section">
    <TeamDates dates={dates} />
  </div>
</div>

<style>
  .rail {
    position: sticky;
    top: 56px;
    padding-top: 8px;
    padding-bottom: 32px;
    align-self: start;
  }
  .rail-section + .rail-section {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }
</style>
