---
import type { REPORTER_CONFIG } from '../config/reporters';
interface Props { config: typeof REPORTER_CONFIG; }
const { config } = Astro.props;
---

<div class="voices">
  <p class="section-label">Reporter Voices</p>
  <p class="voices-sub">The beat reporters who cover this team every day. Follow them for the fastest news.</p>

  <div class="handles-grid">
    {config.handles.map(r => (
      <a href={`https://x.com/${r.handle}`} target="_blank" rel="noopener noreferrer"
         class="handle-card">
        <span class="handle-at">@{r.handle}</span>
        <span class="handle-name">{r.name}</span>
        <span class="handle-outlet">{r.outlet}</span>
      </a>
    ))}
  </div>
</div>

<style>
  .section-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 16px 0 8px;
  }
  .voices-sub {
    font-size: 13px;
    color: var(--text-3);
    margin-bottom: 16px;
  }
  .handles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }
  @media (min-width: 500px) {
    .handles-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 900px) {
    .handles-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .handle-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 3px;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .handle-card:hover {
    border-color: var(--accent);
    background: var(--surface-3);
  }
  .handle-at {
    font-size: 13px;
    font-weight: 700;
    color: var(--text);
  }
  .handle-card:hover .handle-at { color: var(--accent); }
  .handle-name {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-2);
  }
  .handle-outlet {
    font-size: 11px;
    color: var(--text-4);
  }
</style>
