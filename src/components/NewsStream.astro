---
import type { Article } from '../lib/types';
import StoryItem from './StoryItem.astro';
interface Props { items: Article[]; }
const { items } = Astro.props;

const hot   = items.filter(i => i.score >= 75);
const fresh = items.filter(i => i.score >= 50 && i.score < 75);
const rest  = items.filter(i => i.score < 50);
const useGroups = hot.length >= 2 && fresh.length >= 2;

let rank = 1;
---

<div id="filter-banner" class="filter-banner" hidden>
  <span class="filter-banner-label">Showing: <strong id="filter-banner-tag"></strong></span>
  <button class="filter-banner-clear" id="filter-banner-clear" type="button" aria-label="Clear filter">✕ clear</button>
</div>

<div class="stream" id="news-stream">
  {useGroups ? (
    <>
      {hot.length > 0 && (
        <div class="stream-group" id="grp-hot">
          <div class="group-lbl">Major News</div>
          {hot.map(item => <StoryItem item={item} rank={rank++} />)}
        </div>
      )}
      {fresh.length > 0 && (
        <div class="stream-group" id="grp-fresh">
          <div class="group-lbl">Fresh Takes</div>
          {fresh.map(item => <StoryItem item={item} rank={rank++} />)}
        </div>
      )}
      {rest.length > 0 && (
        <div class="stream-group" id="grp-rest">
          <div class="group-lbl">National Chatter</div>
          {rest.map(item => <StoryItem item={item} rank={rank++} />)}
        </div>
      )}
    </>
  ) : (
    <div class="stream-group">
      {items.map(item => <StoryItem item={item} rank={rank++} />)}
    </div>
  )}
</div>

<style>
  /* ── Filter banner ───────────────────────────────────────────────────────── */
  .filter-banner {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 12px;
    margin-bottom: 2px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 13px;
  }
  .filter-banner[hidden] { display: none; }
  .filter-banner-label {
    flex: 1;
    color: var(--text-3);
  }
  .filter-banner-label strong {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .filter-banner-clear {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-4);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 3px 8px;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.12s, border-color 0.12s;
    white-space: nowrap;
  }
  .filter-banner-clear:hover {
    color: var(--text);
    border-color: var(--border-strong);
  }

  /* ── Stream ──────────────────────────────────────────────────────────────── */
  .stream { padding-bottom: 16px; }
  .group-lbl {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-4);
    padding: 14px 0 4px;
  }
  .stream-group:first-child .group-lbl { padding-top: 4px; }
</style>

<script>
  (() => {
    const stream = document.getElementById('news-stream');
    const banner = document.getElementById('filter-banner');
    const bannerTag = document.getElementById('filter-banner-tag');
    const bannerClear = document.getElementById('filter-banner-clear');
    if (!stream || !banner || !bannerTag || !bannerClear) return;

    let activeTag = null;

    function applyFilter(tag) {
      activeTag = tag;

      // Show/hide filter banner
      if (tag) {
        bannerTag.textContent = tag;
        banner.hidden = false;
      } else {
        banner.hidden = true;
      }

      // Filter individual articles
      const articles = stream.querySelectorAll('article[data-tags]');
      articles.forEach(art => {
        const tags = art.dataset.tags ? art.dataset.tags.split(',') : [];
        art.hidden = !!tag && !tags.includes(tag);
      });

      // Hide groups that have no visible articles
      stream.querySelectorAll('.stream-group').forEach(group => {
        const hasVisible = Array.from(group.querySelectorAll('article[data-tags]'))
          .some(a => !a.hidden);
        group.hidden = !hasVisible;
      });
    }

    // Clicking a tag pill inside any article activates that filter
    stream.addEventListener('click', e => {
      const btn = e.target.closest('[data-filter-tag]');
      if (!btn) return;
      e.preventDefault();
      const tag = btn.dataset.filterTag;
      // Tapping same tag again clears it
      applyFilter(activeTag === tag ? null : tag);
    });

    // Clear button resets the filter
    bannerClear.addEventListener('click', () => applyFilter(null));
  })();
</script>
