---
import type { Article, ArticleTag } from '../lib/types';
import StoryItem from './StoryItem.astro';
interface Props { items: Article[]; }
const { items } = Astro.props;

const hot   = items.filter(i => i.score >= 75);
const fresh = items.filter(i => i.score >= 50 && i.score < 75);
const rest  = items.filter(i => i.score < 50);
const useGroups = hot.length >= 2 && fresh.length >= 2;

// Tags available for filtering (in preferred display order)
const FILTER_TAGS: ArticleTag[] = [
  'injury', 'trade', 'signing', 'draft', 'QB',
  'rumor', 'release', 'cap', 'analysis', 'coach', 'stadium',
];
const availableTags = FILTER_TAGS.filter(tag =>
  items.some(i => i.tags.includes(tag))
);

let rank = 1;
---

{availableTags.length > 0 && (
  <div class="tag-bar" id="tag-bar" role="group" aria-label="Filter stories by topic">
    <button class="tf tf--active" data-tag="all" type="button">All</button>
    {availableTags.map(tag => (
      <button class="tf" data-tag={tag} type="button">{tag}</button>
    ))}
  </div>
)}

<div class="stream" id="news-stream">
  {useGroups ? (
    <>
      {hot.length > 0 && (
        <div class="stream-group" id="grp-hot">
          <div class="group-lbl">Major News</div>
          {hot.map(item => <StoryItem item={item} rank={rank++} />)}
        </div>
      )}
      {fresh.length > 0 && (
        <div class="stream-group" id="grp-fresh">
          <div class="group-lbl">Fresh Takes</div>
          {fresh.map(item => <StoryItem item={item} rank={rank++} />)}
        </div>
      )}
      {rest.length > 0 && (
        <div class="stream-group" id="grp-rest">
          <div class="group-lbl">National Chatter</div>
          {rest.map(item => <StoryItem item={item} rank={rank++} />)}
        </div>
      )}
    </>
  ) : (
    <div class="stream-group">
      {items.map(item => <StoryItem item={item} rank={rank++} />)}
    </div>
  )}
</div>

<style>
  /* ── Tag filter bar ──────────────────────────────────────────────────────── */
  .tag-bar {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    padding: 8px 0 12px;
  }

  .tf {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-3);
    cursor: pointer;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
    white-space: nowrap;
    font-family: inherit;
  }
  .tf:hover {
    background: var(--surface-2);
    color: var(--text);
    border-color: var(--border-strong);
  }
  .tf--active {
    background: var(--accent);
    color: #ffffff;
    border-color: transparent;
  }
  :root[data-theme="light"] .tf--active { color: #ffffff; }

  /* ── Stream ──────────────────────────────────────────────────────────────── */
  .stream { padding-bottom: 16px; }
  .group-lbl {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-4);
    padding: 14px 0 4px;
  }
  .stream-group:first-child .group-lbl { padding-top: 4px; }
</style>

<script>
  (() => {
    const bar    = document.getElementById('tag-bar');
    const stream = document.getElementById('news-stream');
    if (!bar || !stream) return;

    bar.addEventListener('click', e => {
      const btn = e.target.closest('[data-tag]');
      if (!btn) return;
      const tag = btn.dataset.tag;

      // Update active button
      bar.querySelectorAll('.tf').forEach(b =>
        b.classList.toggle('tf--active', b === btn)
      );

      // Filter individual articles
      const articles = stream.querySelectorAll('article[data-tags]');
      articles.forEach(art => {
        const tags = art.dataset.tags ? art.dataset.tags.split(',') : [];
        art.hidden = tag !== 'all' && !tags.includes(tag);
      });

      // Hide groups that have no visible articles
      stream.querySelectorAll('.stream-group').forEach(group => {
        const hasVisible = Array.from(group.querySelectorAll('article[data-tags]'))
          .some(a => !a.hidden);
        group.hidden = !hasVisible;
      });
    });
  })();
</script>
