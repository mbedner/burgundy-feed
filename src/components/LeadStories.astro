---
import type { Article } from '../lib/types';
interface Props { items: Article[]; }
const { items } = Astro.props;

const [primary, ...secondaries] = items;

function rel(iso: string): string {
  const m = Math.floor((Date.now() - new Date(iso).getTime()) / 60000);
  if (m < 60) return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24) return `${h}h ago`;
  return `${Math.floor(h / 24)}d ago`;
}
---

<div class="leads">
  <div class="leads-header">
    <span class="section-label">Top Stories</span>
  </div>

  {/* ── Primary lead ── */}
  {primary && (
    <a href={primary.sourceUrl} target="_blank" rel="noopener noreferrer" class="primary">
      {primary.imageUrl && (
        <div class="primary-img-wrap">
          <img
            src={primary.imageUrl}
            alt=""
            class="primary-img"
            loading="lazy"
            onerror="this.closest('.primary-img-wrap').style.display='none'"
          />
        </div>
      )}
      <div class="primary-eyebrow">
        <span class="eyebrow-source">{primary.sourceName}</span>
        {primary.author && <span class="eyebrow-dot">·</span>}
        {primary.author && <span class="eyebrow-author">{primary.author}</span>}
        <span class="eyebrow-dot">·</span>
        <span class="eyebrow-time">{rel(primary.publishedAt)}</span>
        <span class="eyebrow-tags">
          {primary.tags.slice(0, 3).map(tag => (
            <span class={`tag tag--${tag}`}>{tag}</span>
          ))}
        </span>
      </div>
      <h2 class="primary-hed">{primary.displayHeadline}</h2>
      {primary.summary && (
        <p class="primary-summary">{primary.summary.slice(0, 200)}…</p>
      )}
      {primary.originalHeadline !== primary.displayHeadline && (
        <p class="primary-orig">orig: {primary.originalHeadline}</p>
      )}
    </a>
  )}

  {/* ── Secondary leads ── */}
  {secondaries.length > 0 && (
    <div class="secondaries">
      {secondaries.map((item, i) => (
        <a href={item.sourceUrl} target="_blank" rel="noopener noreferrer"
           class={`secondary ${i < secondaries.length - 1 ? 'secondary--border' : ''}`}>
          <div class="secondary-img-wrap">
            {item.imageUrl
              ? <img
                  src={item.imageUrl}
                  alt=""
                  class="secondary-img"
                  loading="lazy"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                />
              : null}
            <div class="img-placeholder" style={item.imageUrl ? 'display:none' : ''}>
              <svg class="placeholder-logo" viewBox="0 0 500 500" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M334.104 124L348.808 169.082L337.868 202.583L312.329 124H197.846L177.311 186.99L156.858 124H20L62.9932 193.815L121.889 374.721H232.712L254.984 306.333L277.194 374.721H398.439L480 124H334.104ZM78.2962 186.722L49.9649 140.73H144.699L168.501 214.04L127.845 338.924L78.2962 186.722ZM220.49 358.363H139.136L205.58 154.254L246.195 279.284L220.49 358.363ZM218.774 140.73H300.169L329.121 229.653L288.382 354.827L218.774 140.73ZM386.135 358.26H304.801L366.344 169.185L357.08 140.73H456.901L386.135 358.26Z" fill="#FFB612"/>
                <path d="M329.058 229.674L288.319 354.848L218.773 140.73H300.169L329.058 229.674ZM357.079 140.73L366.302 169.186L304.76 358.261H386.093L456.942 140.73H357.079ZM144.698 140.73H49.9646L78.2958 186.722L127.927 338.925L168.501 214.04L144.698 140.73ZM139.136 358.261H220.593L246.298 279.285L205.58 154.255L139.136 358.261Z" fill="#5A1414"/>
              </svg>
            </div>
          </div>
          <div class="secondary-eyebrow">
            <span class="eyebrow-source">{item.sourceName}</span>
            <span class="eyebrow-dot">·</span>
            <span class="eyebrow-time">{rel(item.publishedAt)}</span>
            <span class="eyebrow-tags">
              {item.tags.slice(0, 2).map(tag => (
                <span class={`tag tag--${tag}`}>{tag}</span>
              ))}
            </span>
          </div>
          <h3 class="secondary-hed">{item.displayHeadline}</h3>
          {item.originalHeadline !== item.displayHeadline && (
            <p class="secondary-orig">orig: {item.originalHeadline}</p>
          )}
          {item.author && <p class="secondary-author">{item.author}</p>}
        </a>
      ))}
    </div>
  )}
</div>

<style>
  .leads {
    padding-top: 4px;
    min-width: 0;
    overflow: hidden;
  }

  .leads-header { margin-bottom: 14px; }
  .section-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  /* ── Primary ── */
  .primary {
    display: block;
    text-decoration: none;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 16px;
  }

  .primary,
  .secondary { min-width: 0; overflow: hidden; }

  /* Primary image */
  .primary-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 4px;
    margin-bottom: 12px;
    background: var(--surface-2);
  }
  .primary-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .primary:hover .primary-img { transform: scale(1.02); }

  .primary-eyebrow,
  .secondary-eyebrow {
    display: flex;
    align-items: center;
    gap: 5px;
    flex-wrap: wrap;
    margin-bottom: 8px;
    min-width: 0;
  }
  .eyebrow-source {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .eyebrow-author {
    font-size: 12px;
    color: var(--text-3);
  }
  .eyebrow-time {
    font-size: 12px;
    color: var(--text-3);
  }
  .eyebrow-dot {
    font-size: 12px;
    color: var(--text-4);
  }
  .eyebrow-tags {
    display: flex;
    gap: 4px;
    margin-left: 2px;
  }

  .primary-hed {
    font-size: 26px;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 10px;
    transition: color 0.12s;
    word-break: break-word;
  }
  @media (min-width: 640px) {
    .primary-hed { font-size: 30px; }
  }
  .primary:hover .primary-hed { color: var(--accent); }

  .primary-summary {
    font-size: 16px;
    line-height: 1.6;
    color: var(--text-2);
    margin-bottom: 8px;
  }
  .primary-orig {
    font-size: 12px;
    color: var(--text-4);
    font-style: italic;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 100%;
  }

  /* ── Secondaries ── */
  .secondaries {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 560px) {
    .secondaries {
      grid-template-columns: 1fr 1fr;
      column-gap: 40px;
      position: relative;
    }
    /* Vertical divider between the two cards via a centred pseudo-element */
    .secondaries::after {
      content: '';
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 14px;              /* match card bottom padding */
      width: 1px;
      background: var(--border);
      transform: translateX(-50%);
      pointer-events: none;
    }
  }

  .secondary {
    display: block;
    text-decoration: none;
    padding: 0 0 14px;
  }
  /* No extra padding/margin on border card — gap is handled by column-gap above */
  .secondary--border {
    /* left intentionally empty; kept for backward compat */
  }
  @media (max-width: 559px) {
    .secondary--border {
      border-bottom: 1px solid var(--border);
      padding-bottom: 14px;
      margin-bottom: 14px;
    }
  }

  /* Secondary image */
  .secondary-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 3px;
    margin-bottom: 10px;
    background: var(--surface-2);
    position: relative;
  }
  .secondary-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .secondary:hover .secondary-img { transform: scale(1.02); }

  /* Placeholder card shown when no image is available */
  .img-placeholder {
    position: absolute;
    inset: 0;
    background: #9b1535;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .placeholder-logo {
    width: 52px;
    height: auto;
    opacity: 0.85;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.4));
    transition: opacity 0.2s;
  }
  .secondary:hover .img-placeholder { background: #7a1028; }
  .secondary:hover .placeholder-logo { opacity: 1; }

  .secondary-hed {
    font-size: 19px;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--text);
    margin-bottom: 5px;
    transition: color 0.12s;
    word-break: break-word;
  }
  .secondary:hover .secondary-hed { color: var(--accent); }

  .secondary-orig {
    font-size: 12px;
    color: var(--text-4);
    font-style: italic;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 100%;
    margin-bottom: 3px;
  }
  .secondary-author {
    font-size: 12px;
    color: var(--text-3);
    margin-top: 2px;
  }

  /* ── Tags ── */
  .tag {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 3px;
    background: var(--surface-3);
    color: var(--text-3);
    flex-shrink: 0;
  }
</style>
